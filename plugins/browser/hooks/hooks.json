{
  "description": "Auto-logs agent-browser interactions for flow generation and recording",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/interaction-logger.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
